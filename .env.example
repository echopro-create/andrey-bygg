# Telegram Bot Configuration for Booking Notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Site URL (used for sitemap, canonical URLs, OG tags)
NEXT_PUBLIC_SITE_URL=https://byggisyd.se

# Google reCAPTCHA v3 (optional, for booking form anti-spam)
